---
import Base from "./Base.astro";

interface FaqItem {
  q: string;
  a: string;
}

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  tldr?: string;
  faq?: FaqItem[];
  date: Date;
  updated?: Date;
  tags?: string[];
  canonicalUrl?: string;
  ogImage?: string;
  originalUrl?: string;
  readingTime?: number;
  wordCount?: number;
  noindex?: boolean;
  headings?: Heading[];
  prevPost?: { title: string; url: string } | null;
  nextPost?: { title: string; url: string } | null;
  relatedPosts?: { title: string; url: string }[];
}

const {
  title,
  description,
  tldr,
  faq = [],
  date,
  updated,
  tags = [],
  canonicalUrl,
  ogImage,
  originalUrl,
  readingTime,
  wordCount,
  noindex = false,
  headings = [],
  prevPost,
  nextPost,
  relatedPosts = [],
} = Astro.props;

const siteUrl = "https://tanchao.xyz";
const dateStr = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const updatedStr = updated
  ? updated.toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;

const postUrl = canonicalUrl ?? new URL(Astro.url.pathname, siteUrl).href;
const resolvedOg = ogImage
  ? ogImage.startsWith("http")
    ? ogImage
    : new URL(ogImage, siteUrl).href
  : new URL("/og-default.png", siteUrl).href;
const schemaDescription = description ?? tldr;

const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description: schemaDescription,
  datePublished: date.toISOString(),
  dateModified: (updated ?? date).toISOString(),
  author: {
    "@type": "Person",
    "@id": `${siteUrl}/#person`,
    name: "Chao Tan",
  },
  publisher: {
    "@type": "Person",
    "@id": `${siteUrl}/#person`,
    name: "Chao Tan",
  },
  url: postUrl,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": postUrl,
  },
  image: resolvedOg,
  ...(wordCount ? { wordCount } : {}),
  keywords: tags.join(", "),
  inLanguage: "en-US",
  isPartOf: { "@type": "WebSite", "@id": `${siteUrl}/#website` },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
    { "@type": "ListItem", position: 2, name: "Posts", item: `${siteUrl}/posts/` },
    { "@type": "ListItem", position: 3, name: title, item: postUrl },
  ],
};

const faqSchema =
  faq.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: faq.map(({ q, a }) => ({
          "@type": "Question",
          name: q,
          acceptedAnswer: { "@type": "Answer", text: a },
        })),
      }
    : null;

const jsonLd = [blogPostingSchema, breadcrumbSchema, ...(faqSchema ? [faqSchema] : [])];

const tocHeadings = headings.filter((h) => h.depth === 2);
---

<Base
  title={title}
  description={schemaDescription}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
  type="article"
  publishedTime={date}
  updatedTime={updated}
  tags={tags}
  noindex={noindex}
  jsonLd={jsonLd}
>
  <article>
    <header style="margin-bottom:2rem;">
      <h1 style="margin-bottom:0.5rem;">{title}</h1>
      <div style="font-family:var(--font-sans);font-size:0.875rem;color:var(--text-muted);display:flex;flex-wrap:wrap;gap:0.75rem;align-items:center;">
        <time datetime={date.toISOString()}>{dateStr}</time>
        {updatedStr && <span>· updated {updatedStr}</span>}
        {readingTime && <span>· {readingTime} min read</span>}
      </div>
      {tags.length > 0 && (
        <div style="margin-top:0.75rem;display:flex;flex-wrap:wrap;gap:0.375rem;">
          {tags.map(tag => (
            <a href={`/tags/${tag}/`} class="tag-pill">{tag}</a>
          ))}
        </div>
      )}
      {originalUrl && (
        <p style="margin-top:0.75rem;font-family:var(--font-sans);font-size:0.8rem;color:var(--text-muted);">
          Originally at <a href={originalUrl} rel="noopener">{originalUrl}</a>
        </p>
      )}
    </header>

    {tldr && (
      <blockquote
        class="tldr"
        style="background:var(--bg-alt);border-left:3px solid var(--link);padding:1rem 1.25rem;margin:0 0 2rem;font-family:var(--font-serif);font-size:1rem;line-height:1.6;"
      >
        <strong style="font-family:var(--font-sans);font-size:0.75rem;letter-spacing:0.05em;text-transform:uppercase;color:var(--text-muted);display:block;margin-bottom:0.5rem;">
          TL;DR
        </strong>
        {tldr}
      </blockquote>
    )}

    {tocHeadings.length >= 3 && (
      <nav
        aria-label="Table of contents"
        style="background:var(--bg-alt);border:1px solid var(--border);border-radius:6px;padding:1rem 1.25rem;margin-bottom:2rem;font-family:var(--font-sans);font-size:0.875rem;"
      >
        <p style="margin:0 0 0.5rem;font-weight:600;font-size:0.8rem;letter-spacing:0.05em;text-transform:uppercase;color:var(--text-muted);">
          Contents
        </p>
        <ol style="margin:0;padding-left:1.25rem;">
          {tocHeadings.map(h => (
            <li style="margin:0.25rem 0;">
              <a href={`#${h.slug}`} style="color:var(--text-muted);">{h.text}</a>
            </li>
          ))}
        </ol>
      </nav>
    )}

    <div class="prose">
      <slot />
    </div>

    {faq.length > 0 && (
      <section
        aria-label="FAQ"
        style="margin-top:3rem;padding-top:1.5rem;border-top:1px solid var(--border);"
      >
        <h2 style="font-family:var(--font-sans);font-size:1.125rem;margin-bottom:1rem;">FAQ</h2>
        <dl style="margin:0;">
          {faq.map(({ q, a }) => (
            <>
              <dt style="font-family:var(--font-sans);font-weight:600;margin:1rem 0 0.25rem;">{q}</dt>
              <dd style="margin:0 0 0.5rem;color:var(--text-muted);">{a}</dd>
            </>
          ))}
        </dl>
      </section>
    )}
  </article>

  <script>
    async function renderMermaid() {
      const nodes = document.querySelectorAll<HTMLElement>(
        "pre.mermaid[data-mermaid-source]"
      );
      if (nodes.length === 0) return;

      const { default: mermaid } = await import("mermaid");
      const theme =
        document.documentElement.getAttribute("data-theme") ?? "light";
      const isDark = theme === "dark" || theme === "solarized" || theme === "nord";

      mermaid.initialize({
        startOnLoad: false,
        securityLevel: "strict",
        theme: isDark ? "dark" : "default",
        fontFamily: "system-ui, -apple-system, sans-serif",
      });

      for (const node of nodes) {
        const stored = node.dataset.mermaidSource;
        const source = stored && stored.length > 0 ? stored : node.textContent ?? "";
        if (!stored || stored.length === 0) {
          node.dataset.mermaidSource = source;
        }
        const id = `mermaid-${Math.random().toString(36).slice(2, 10)}`;
        try {
          const { svg } = await mermaid.render(id, source);
          node.innerHTML = svg;
          node.classList.add("mermaid-rendered");
        } catch (err) {
          console.error("[mermaid] render failed", err);
          node.classList.add("mermaid-error");
        }
      }
    }

    renderMermaid();

    let rerenderTimer: number | undefined;
    const observer = new MutationObserver(() => {
      window.clearTimeout(rerenderTimer);
      rerenderTimer = window.setTimeout(() => {
        document
          .querySelectorAll<HTMLElement>("pre.mermaid.mermaid-rendered")
          .forEach((node) => {
            node.innerHTML = "";
            node.classList.remove("mermaid-rendered");
          });
        renderMermaid();
      }, 50);
    });
    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-theme"],
    });
  </script>

  {relatedPosts.length > 0 && (
    <aside
      style="margin-top:3rem;padding-top:1.5rem;border-top:1px solid var(--border);font-family:var(--font-sans);"
      aria-label="Related posts"
    >
      <p style="font-size:0.8rem;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;color:var(--text-muted);margin-bottom:0.75rem;">
        Related
      </p>
      <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.375rem;">
        {relatedPosts.map(p => (
          <li>
            <a href={p.url} style="font-size:0.9rem;">{p.title}</a>
          </li>
        ))}
      </ul>
    </aside>
  )}

  {(prevPost || nextPost) && (
    <nav
      aria-label="Post navigation"
      style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--border);display:grid;grid-template-columns:1fr 1fr;gap:1rem;font-family:var(--font-sans);font-size:0.875rem;"
    >
      <div>
        {prevPost && (
          <>
            <p style="color:var(--text-muted);margin-bottom:0.25rem;">← Older</p>
            <a href={prevPost.url}>{prevPost.title}</a>
          </>
        )}
      </div>
      <div style="text-align:right;">
        {nextPost && (
          <>
            <p style="color:var(--text-muted);margin-bottom:0.25rem;">Newer →</p>
            <a href={nextPost.url}>{nextPost.title}</a>
          </>
        )}
      </div>
    </nav>
  )}
</Base>
