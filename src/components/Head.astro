---
interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  type?: "website" | "article";
  publishedTime?: Date;
  updatedTime?: Date;
  tags?: string[];
}

const {
  title,
  description = "Chao Tan — data governance and privacy engineer. Writes about data governance, AI system security, performance engineering, and career.",
  canonicalUrl,
  ogImage = "/og-default.png",
  type = "website",
  publishedTime,
  updatedTime,
  tags = [],
} = Astro.props;

const siteUrl = "https://tanchao.xyz";
const resolvedCanonical = canonicalUrl ?? new URL(Astro.url.pathname, siteUrl).href;
const resolvedOg = ogImage.startsWith("http") ? ogImage : new URL(ogImage, siteUrl).href;
const fullTitle = title === "tanchao's blog" ? title : `${title} — tanchao's blog`;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={resolvedCanonical} />

<!-- Open Graph -->
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={resolvedCanonical} />
<meta property="og:image" content={resolvedOg} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="tanchao's blog — data governance · AI security · engineering" />
<meta property="og:type" content={type} />
<meta property="og:site_name" content="tanchao's blog" />
<meta property="og:locale" content="en_US" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={resolvedOg} />
<meta name="twitter:site" content="@chaostan" />
<meta name="twitter:creator" content="@chaostan" />

<!-- Article-specific -->
{type === "article" && publishedTime && (
  <meta property="article:published_time" content={publishedTime.toISOString()} />
)}
{type === "article" && updatedTime && (
  <meta property="article:modified_time" content={updatedTime.toISOString()} />
)}
{type === "article" && tags.map(tag => (
  <meta property="article:tag" content={tag} />
))}
{type === "article" && (
  <meta property="article:author" content="Chao Tan" />
)}

<!-- Feeds -->
<link
  rel="alternate"
  type="application/rss+xml"
  href={`${siteUrl}/rss.xml`}
  title="tanchao's blog RSS Feed"
/>

<!-- Favicon & Icons -->
<link rel="icon" href="/favicon.ico" sizes="32x32" />
<link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

<!-- Meta -->
<meta name="author" content="Chao Tan" />
<meta name="theme-color" content="#171717" media="(prefers-color-scheme: dark)" />
<meta name="theme-color" content="#fafaf8" media="(prefers-color-scheme: light)" />

<!-- Cloudflare Web Analytics — set CF_ANALYTICS_TOKEN in CF Pages env vars -->
{import.meta.env.CF_ANALYTICS_TOKEN && (
  <script
    is:inline
    defer
    src="https://static.cloudflareinsights.com/beacon.min.js"
    data-cf-beacon={`{"token":"${import.meta.env.CF_ANALYTICS_TOKEN}"}`}
  />
)}

<!-- Theme script (runs before paint to avoid flash) -->
<script is:inline>
  (function () {
    var THEMES = ["light", "dark", "sepia", "solarized", "nord"];
    var stored = localStorage.getItem("theme");
    var theme;
    if (stored && THEMES.indexOf(stored) !== -1) {
      theme = stored;
    } else {
      theme = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
    }
    document.documentElement.setAttribute("data-theme", theme);
  })();
</script>
