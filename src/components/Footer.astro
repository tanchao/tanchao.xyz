---
const year = new Date().getFullYear();
---

<footer style="border-top:1px solid var(--border);margin-top:4rem;padding:2rem 0;">
  <div style="max-width:48rem;margin:0 auto;padding:0 1.5rem;display:flex;flex-wrap:wrap;gap:1rem;justify-content:space-between;align-items:center;">
    <p style="font-family:var(--font-sans);font-size:0.85rem;color:var(--text-muted);margin:0;">
      © {year} Chao Tan ·
      <a href="/rss.xml" style="color:var(--text-muted);text-decoration:underline;text-underline-offset:3px;">RSS</a>
      ·
      <a href="/llms.txt" style="color:var(--text-muted);text-decoration:underline;text-underline-offset:3px;">llms.txt</a>
      ·
      <a href="/humans.txt" style="color:var(--text-muted);text-decoration:underline;text-underline-offset:3px;">humans.txt</a>
      ·
      <a href="/feedback/" style="color:var(--text-muted);text-decoration:underline;text-underline-offset:3px;">Suggest an improvement</a>
    </p>
    <p style="font-family:var(--font-sans);font-size:0.8rem;color:var(--text-muted);margin:0;">
      All opinions are my own.
    </p>
  </div>
</footer>
