---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import { noteSlug, sortedNotes } from "../../lib/posts";

export async function getStaticPaths() {
  const includeDrafts = !import.meta.env.PROD;
  const notes = sortedNotes(await getCollection("notes"), includeDrafts);
  return notes.map(note => ({
    params: { slug: noteSlug(note.id) },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);

const dateStr = note.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

// Self-canonical: this is the indexable copy on tanchao.xyz.
// Syndicated notes link to the original source (e.g. Substack) in the body
// for attribution, but the canonical URL must be the local one — otherwise
// Google treats the page as a duplicate of a URL that itself redirects, and
// neither the local nor the source copy ends up in our index.
const noteCanonical = new URL(`/notes/${noteSlug(note.id)}/`, "https://tanchao.xyz").href;
const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: note.data.title,
  datePublished: note.data.date.toISOString(),
  dateModified: note.data.date.toISOString(),
  author: { "@type": "Person", "@id": "https://tanchao.xyz/#person", name: "Chao Tan" },
  url: noteCanonical,
  ...(note.data.sourceUrl ? { sameAs: note.data.sourceUrl } : {}),
  isPartOf: { "@type": "WebSite", "@id": "https://tanchao.xyz/#website" },
  inLanguage: "en-US",
};
---

<Base
  title={note.data.title}
  type="article"
  publishedTime={note.data.date}
  canonicalUrl={noteCanonical}
  noindex={note.data.draft}
  jsonLd={blogPostingSchema}
>
  <article>
    <header style="margin-bottom:2rem;">
      <h1>{note.data.title}</h1>
      <time
        datetime={note.data.date.toISOString()}
        style="font-family:var(--font-sans);font-size:0.875rem;color:var(--text-muted);"
      >
        {dateStr}
      </time>
      {note.data.sourceUrl && (
        <div style="margin-top:0.5rem;">
          <a
            href={note.data.sourceUrl}
            rel="noopener noreferrer"
            style="font-family:var(--font-sans);font-size:0.85rem;color:var(--text-muted);"
          >
            Originally posted on Substack ↗
          </a>
        </div>
      )}
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
  <p style="margin-top:2rem;font-family:var(--font-sans);font-size:0.875rem;">
    <a href="/notes/">← All notes</a>
  </p>
</Base>
