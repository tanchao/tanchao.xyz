---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import { noteSlug } from "../../lib/posts";

export async function getStaticPaths() {
  const notes = await getCollection("notes");
  return notes.map(note => ({
    params: { slug: noteSlug(note.id) },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);

const dateStr = note.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const noteCanonical = new URL(`/notes/${noteSlug(note.id)}/`, "https://tanchao.xyz").href;
const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: note.data.title,
  datePublished: note.data.date.toISOString(),
  dateModified: note.data.date.toISOString(),
  author: { "@type": "Person", "@id": "https://tanchao.xyz/#person", name: "Chao Tan" },
  url: noteCanonical,
  isPartOf: { "@type": "Blog", "@id": "https://tanchao.xyz/#website" },
  inLanguage: "en-US",
};
---

<Base title={note.data.title} type="article" publishedTime={note.data.date} canonicalUrl={noteCanonical} jsonLd={blogPostingSchema}>
  <article>
    <header style="margin-bottom:2rem;">
      <h1>{note.data.title}</h1>
      <time
        datetime={note.data.date.toISOString()}
        style="font-family:var(--font-sans);font-size:0.875rem;color:var(--text-muted);"
      >
        {dateStr}
      </time>
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
  <p style="margin-top:2rem;font-family:var(--font-sans);font-size:0.875rem;">
    <a href="/notes/">← All notes</a>
  </p>
</Base>
