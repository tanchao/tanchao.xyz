---
import Base from "../layouts/Base.astro";
import JsonLd from "../components/JsonLd.astro";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": "https://tanchao.xyz/#person",
  name: "Chao Tan",
  alternateName: ["tc", "tanchao"],
  givenName: "Chao",
  familyName: "Tan",
  url: "https://tanchao.xyz",
  email: "chaos.tc@gmail.com",
  sameAs: [
    "https://github.com/tanchao",
    "https://twitter.com/chaostan",
    "https://www.linkedin.com/in/tanchao",
    "https://substack.com/@sprtn",
  ],
  jobTitle: "Data Governance & Privacy Engineer",
  worksFor: {
    "@type": "Organization",
    name: "Snowflake",
    url: "https://snowflake.com",
  },
  knowsAbout: [
    "data governance",
    "data privacy",
    "data classification",
    "AI system governance",
    "AI security",
    "sensitive data discovery",
    "distributed systems",
    "performance tuning",
    "API design",
    "microservices",
    "Snowflake",
    "Java",
    "Python",
  ],
  alumniOf: [
    { "@type": "Organization", name: "Amazon" },
    { "@type": "Organization", name: "HSBC" },
    { "@type": "Organization", name: "eBay" },
  ],
  hasCredential: [
    {
      "@type": "CreativeWork",
      name: "Efficient Computation over a Wide Table",
      identifier: "US20260003847A1",
      url: "https://patents.google.com/patent/US20260003847A1/en",
      dateCreated: "2024-06-26",
    },
    {
      "@type": "CreativeWork",
      name: "Automatic Tag Propagation",
      identifier: "US20250371036A1",
      url: "https://patents.google.com/patent/US20250371036A1/en",
      dateCreated: "2024-08-07",
    },
    {
      "@type": "CreativeWork",
      name: "Column Classification Model",
      identifier: "US20240330412A1",
      url: "https://patents.google.com/patent/US20240330412A1/en",
      dateCreated: "2023-03-29",
    },
  ],
  description:
    "Data governance and privacy engineer with 18 years of experience building and securing large-scale data systems. Built Snowflake's data classification platform. Former Amazon Alexa tech lead. Expert in data governance, AI system security, and performance engineering.",
};
---

<Base
  title="About"
  description="About Chao Tan — data governance and privacy engineer at Snowflake. 18 years building and securing large-scale systems. Former Amazon Alexa tech lead."
  jsonLd={personSchema}
  suppressGlobalPerson
>
  <h1>About Me</h1>

  <div class="prose h-card">
    <p class="p-name" style="display:none;">Chao Tan</p>
    <a class="u-url" href="https://tanchao.xyz/" style="display:none;">tanchao.xyz</a>
    <a class="u-email" href="mailto:chaos.tc@gmail.com" style="display:none;">chaos.tc@gmail.com</a>

    <p>
      My name is <strong>Chao Tan</strong> (谭超). Call me <code>Chao</code> or <code>tc</code>.
    </p>

    <p>
      I'm a data governance and privacy engineer at <strong>Snowflake</strong> in Bellevue, Washington. I built the data classification platform that automatically discovers and tags sensitive data across Snowflake's cloud — the system that helps organizations understand what data they have, where it is, and how it should be protected.
    </p>

    <p>
      Before Snowflake, I spent six years at <strong>Amazon</strong> as a tech lead on Alexa's cloud platform services. I owned APIs serving hundreds of millions of requests, led a 14-person engineering team through a major infrastructure decoupling that impacted 10,000+ internal developers, and built the backend for Amazon's consumer robot (Astro) from scratch.
    </p>

    <p>
      I've been building software since 2004, across four companies and three countries. Automation methodology at eBay, global distributed systems at HSBC, ownership culture at Amazon, and now data governance at Snowflake. Each place taught me something the previous one couldn't.
    </p>

    <h2>Domain expertise</h2>
    <ul>
      <li><strong>Data governance and privacy</strong> — classification, tagging, sensitive data discovery, compliance automation</li>
      <li><strong>AI system governance</strong> — securing and governing data pipelines that feed AI/ML workloads</li>
      <li><strong>Performance engineering</strong> — 10x improvements, p50/p90 compression, architecture-level optimization (O(N) to O(log N))</li>
      <li><strong>API design and distributed systems</strong> — Tier-1 services at 100k+ TPS, microservices architecture, platform APIs</li>
      <li><strong>Technical leadership</strong> — led teams of 14+ engineers, coached sister teams, operated through ambiguity</li>
    </ul>

    <h2>What I believe in</h2>
    <ul>
      <li>Long-term engineering value over short-term velocity</li>
      <li>Automation over process — if it can be automated, it should be</li>
      <li><code>SDE = Somebody Do Everything</code> — not just code, but the full outcome</li>
      <li>First principles thinking before reaching for tools</li>
      <li>Stay foolish, stay hungry</li>
    </ul>

    <h2>Patent applications</h2>
    <ul>
      <li>
        <a href="https://patents.google.com/patent/US20260003847A1/en" rel="noopener">Efficient Computation over a Wide Table</a>
        — US20260003847A1 · Snowflake Inc. · Filed Jun 2024
      </li>
      <li>
        <a href="https://patents.google.com/patent/US20250371036A1/en" rel="noopener">Automatic Tag Propagation</a>
        — US20250371036A1 · Snowflake Inc. · Filed Aug 2024
      </li>
      <li>
        <a href="https://patents.google.com/patent/US20240330412A1/en" rel="noopener">Column Classification Model</a>
        — US20240330412A1 · Snowflake Inc. · Filed Mar 2023
      </li>
    </ul>

    <h2>Outside work</h2>
    <p>
      Art, food, basketball, swimming, and skiing. Father of two.
    </p>

    <h2>Contact</h2>
    <p>
      <a href="mailto:chaos.tc@gmail.com">chaos.tc@gmail.com</a> ·
      <a href="https://github.com/tanchao" rel="noopener">GitHub</a> ·
      <a href="https://twitter.com/chaostan" rel="noopener">Twitter @chaostan</a>
    </p>
  </div>
</Base>
