---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
import { sortedPosts, postUrl, allTags } from "../../lib/posts";

const posts = sortedPosts(await getCollection("posts"));
const tags = allTags(posts);

const byYear = new Map<number, typeof posts>();
for (const post of posts) {
  const year = post.data.date.getFullYear();
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(post);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---

<Base title="Posts" description="All posts by Chao Tan, grouped by year.">
  <h1>Posts</h1>

  {tags.length > 0 && (
    <div style="margin-bottom:2rem;display:flex;flex-wrap:wrap;gap:0.375rem;">
      {tags.map(tag => (
        <a href={`/tags/${tag}/`} class="tag-pill">{tag}</a>
      ))}
    </div>
  )}

  {years.map(year => (
    <div style="margin-bottom:2.5rem;">
      <h2 style="font-family:var(--font-sans);font-size:1rem;font-weight:600;color:var(--text-muted);letter-spacing:0.05em;text-transform:uppercase;border-bottom:1px solid var(--border);padding-bottom:0.375rem;margin-bottom:0.75rem;">
        {year}
      </h2>
      <ul style="list-style:none;padding:0;margin:0;">
        {byYear.get(year)!.map(post => (
          <li style="display:flex;gap:1rem;align-items:baseline;padding:0.3rem 0;flex-wrap:wrap;">
            <time
              datetime={post.data.date.toISOString()}
              style="font-family:var(--font-sans);font-size:0.85rem;color:var(--text-muted);white-space:nowrap;min-width:6rem;"
            >
              {post.data.date.toLocaleDateString("en-US", { month: "short", day: "numeric" })}
            </time>
            <a href={postUrl(post.id)}>{post.data.title}</a>
          </li>
        ))}
      </ul>
    </div>
  ))}
</Base>
