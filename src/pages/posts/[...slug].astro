---
import { getCollection, render } from "astro:content";
import Post from "../../layouts/Post.astro";
import { postSlug, postUrl, readingTime, sortedPosts, wordCount } from "../../lib/posts";

export async function getStaticPaths() {
  const includeDrafts = !import.meta.env.PROD;
  const posts = sortedPosts(await getCollection("posts"), includeDrafts);
  return posts.map((post, i) => {
    const slug = postSlug(post.id);
    const prevPost = posts[i + 1]
      ? { title: posts[i + 1].data.title, url: postUrl(posts[i + 1].id) }
      : null;
    const nextPost = posts[i - 1]
      ? { title: posts[i - 1].data.title, url: postUrl(posts[i - 1].id) }
      : null;
    return {
      params: { slug },
      props: { post, prevPost, nextPost },
    };
  });
}

const { post, prevPost, nextPost } = Astro.props;
const { Content, headings } = await render(post);
const body = post.body ?? "";
const rt = readingTime(body);
const wc = wordCount(body);

const allPosts = sortedPosts(await getCollection("posts"));
const currentTags = new Set(post.data.tags);
const relatedPosts = allPosts
  .filter(p => p.id !== post.id)
  .map(p => ({ post: p, shared: p.data.tags.filter(t => currentTags.has(t)).length }))
  .filter(r => r.shared > 0)
  .sort((a, b) => b.shared - a.shared)
  .slice(0, 3)
  .map(r => ({ title: r.post.data.title, url: postUrl(r.post.id) }));
---

<Post
  title={post.data.title}
  description={post.data.description}
  tldr={post.data.tldr}
  faq={post.data.faq}
  date={post.data.date}
  updated={post.data.updated}
  tags={post.data.tags}
  canonicalUrl={post.data.canonical}
  ogImage={post.data.image}
  originalUrl={post.data.originalUrl}
  readingTime={rt}
  wordCount={wc}
  noindex={post.data.draft}
  headings={headings}
  prevPost={prevPost}
  nextPost={nextPost}
  relatedPosts={relatedPosts}
>
  <Content />
</Post>
