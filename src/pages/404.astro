---
import Base from "../layouts/Base.astro";
---

<Base title="Page Not Found">
  <div style="text-align:center;padding:4rem 0;">
    <h1 style="font-size:4rem;color:var(--text-muted);margin-bottom:0.5rem;">404</h1>
    <p style="font-family:var(--font-sans);font-size:1.125rem;color:var(--text-muted);margin-bottom:2rem;">
      This page doesn't exist.
    </p>
    <div style="display:flex;gap:1rem;justify-content:center;font-family:var(--font-sans);">
      <a href="/">← Home</a>
      <a href="/posts/">Posts</a>
      <a href="/about/">About</a>
    </div>
  </div>
</Base>
