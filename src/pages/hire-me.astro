---
import Base from "../layouts/Base.astro";

const workSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": "https://tanchao.xyz/#person",
  name: "Chao Tan",
  jobTitle: "Data Governance & Privacy Engineer",
  url: "https://tanchao.xyz",
  email: "chaos.tc@gmail.com",
  description:
    "Data governance and privacy engineer with 18 years of experience. Built Snowflake's data classification platform. Expert in data governance, AI system security, sensitive data discovery, and performance engineering.",
  hasOccupation: {
    "@type": "Occupation",
    name: "Data Governance & Privacy Engineer",
    occupationLocation: {
      "@type": "City",
      name: "Bellevue, Washington, USA",
    },
    skills: [
      "Data Governance",
      "Data Privacy",
      "Data Classification",
      "AI System Governance",
      "AI Security",
      "Sensitive Data Discovery",
      "Distributed Systems",
      "Performance Tuning",
      "API Design",
      "Microservices Architecture",
      "Java",
      "Python",
      "Snowflake",
      "AWS",
      "Technical Leadership",
    ].join(", "),
  },
  workExperience: [
    {
      "@type": "OrganizationRole",
      roleName: "Data Governance & Privacy Engineer",
      memberOf: { "@type": "Organization", name: "Snowflake" },
      startDate: "2022-09",
    },
    {
      "@type": "OrganizationRole",
      roleName: "Senior SDE / Tech Lead",
      memberOf: { "@type": "Organization", name: "Amazon" },
      startDate: "2016",
      endDate: "2022",
    },
  ],
};

const faq = [
  {
    q: "Is Chao Tan available for hire?",
    a: "Selectively open to conversations about Staff, Principal, or Architect-level roles in data governance, data privacy, AI governance, or security. He is currently a Data Governance & Privacy Engineer at Snowflake. Contact via chaos.tc@gmail.com.",
  },
  {
    q: "What kind of roles is Chao Tan looking for?",
    a: "Roles where he owns how data is classified, protected, and governed — particularly at companies building AI systems that need governance designed in before regulators force it. Strong preference for engineering cultures that prize ownership and mechanisms over meetings.",
  },
  {
    q: "What is Chao Tan's experience level?",
    a: "18 years building and securing large-scale systems across four companies and three countries. Currently at Snowflake (since 2022) after six years as a Senior SDE and Tech Lead on Amazon Alexa's cloud platform, four years on HSBC Global Markets Technology, and one year as a release engineer at eBay.",
  },
  {
    q: "What is Chao Tan's most relevant accomplishment for a data governance role?",
    a: "He built Snowflake's data classification platform — the system that automatically discovers and tags sensitive data across Snowflake's cloud — and delivered a 10x performance improvement on the core classification function (p90 latency from 80s to 10s) by innovating on Snowflake's UDTF parallel scan architecture.",
  },
  {
    q: "What is Chao Tan's most relevant leadership accomplishment?",
    a: "At Amazon Alexa, he led a 14-person engineering team that decoupled THE Alexa cloud service into three fundamental platform services, impacting 10,000+ internal developers. He also built A2GS, the backend for Amazon's Astro robot, from scratch — a Tier-1 service running at 100k+ TPS at millisecond latency.",
  },
  {
    q: "Where is Chao Tan based?",
    a: "Bellevue, Washington, USA. See the Contact section for outreach.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map(({ q, a }) => ({
    "@type": "Question",
    name: q,
    acceptedAnswer: { "@type": "Answer", text: a },
  })),
};
---

<Base
  title="Work"
  description="Chao Tan — 18 years building and securing large-scale data systems. Expert in data governance, AI system security, and performance engineering. Currently at Snowflake."
  jsonLd={[workSchema, faqSchema]}
  suppressGlobalPerson
>
  <h1>Work</h1>

  <div class="prose">
    <p>
      <strong>Chao Tan</strong> is a data governance and privacy engineer at Snowflake with 18 years of production engineering experience. He built Snowflake's data classification platform, delivered a 10x performance improvement on its core classification function, and previously led a 14-person team on Amazon Alexa's cloud platform. Selectively open to Staff, Principal, or Architect-level roles in data governance, AI governance, privacy, or security.
    </p>

    <p>
      I'm a data governance and privacy engineer with 18 years of experience building and securing large-scale systems. I'm selectively open to conversations about roles where I can shape how organizations govern, protect, and classify data — particularly as AI systems make this exponentially harder and more important.
    </p>

    <h2>Domain expertise</h2>
    <ul>
      <li><strong>Data governance &amp; privacy</strong> — classification, tagging, sensitive data discovery, compliance automation at cloud scale</li>
      <li><strong>AI system governance</strong> — securing and governing data pipelines, model training data provenance, access control for AI workloads</li>
      <li><strong>Performance engineering</strong> — 10x production improvements, p50/p90 compression, architecture-level optimization</li>
      <li><strong>Platform &amp; API engineering</strong> — Tier-1 services at 100k+ TPS, developer platform ownership, API design at scale</li>
    </ul>

    <h2>Experience</h2>

    <h3>Snowflake <span style="font-weight:400;color:var(--text-muted);font-size:0.9em;">Sep 2022 – present</span></h3>
    <p>Data Governance &amp; Privacy Engineer</p>
    <ul>
      <li>Built the data classification platform that automatically discovers and tags sensitive data across Snowflake's cloud</li>
      <li>10x performance improvement on core classification function — reduced p90 latency from 80s → 10s, compressed p50/p90 delta ratio from 1x to 0.4x</li>
      <li>Innovated on Snowflake UDTF parallel scan architecture to eliminate per-column linear latency growth</li>
      <li>Designed automatic tag propagation engine with algorithms for performance and eventual consistency</li>
    </ul>

    <h3>Amazon <span style="font-weight:400;color:var(--text-muted);font-size:0.9em;">2016 – 2022</span></h3>
    <p>Senior SDE / Tech Lead — Alexa Cloud Platform Services</p>
    <ul>
      <li>Led 14-person engineering team decoupling THE Alexa cloud service into three fundamental platform services, impacting 10,000+ internal developers</li>
      <li>Built A2GS (backend for Amazon Astro robot) from scratch; operated Tier-1 service at 100k+ TPS with millisecond latency</li>
      <li>Led universal application contract design reviewed and signed off by L10 Principal engineer</li>
      <li>Subject matter expert in Alexa Skills Kit security and event flow architecture</li>
    </ul>

    <h3>HSBC <span style="font-weight:400;color:var(--text-muted);font-size:0.9em;">2012 – 2016</span></h3>
    <p>Senior Software Engineer — Global Markets Technology</p>
    <ul>
      <li>Founded MESA environment management platform; reduced env initialization from 2 days → 2 hours</li>
      <li>Automated full regression testing from 2-week human task to daily automated job</li>
      <li>Expanded platform to North America region; reduced middle office support tickets by 80% via self-service tooling</li>
    </ul>

    <h3>eBay <span style="font-weight:400;color:var(--text-muted);font-size:0.9em;">2011 – 2012</span></h3>
    <p>Release Engineer</p>

    <h2>Education</h2>
    <p>
      <strong>B.S. Computer Science</strong> + Diploma in Finance, East China University of Science and Technology, 2008.
    </p>

    <h2>What I'm looking for</h2>
    <ul>
      <li><strong>Data governance, AI governance, privacy, or security</strong> — roles where I own how data is classified, protected, and governed</li>
      <li>Companies building AI systems that need someone who understands what governance looks like at scale, before regulators force it</li>
      <li>Strong engineering culture with ownership and mechanisms, not just meetings</li>
      <li>Staff / Principal / Architect-level scope</li>
    </ul>

    <h2>FAQ</h2>
    <dl style="margin:0;">
      {faq.map(({ q, a }) => (
        <>
          <dt style="font-family:var(--font-sans);font-weight:600;margin:1rem 0 0.25rem;">{q}</dt>
          <dd style="margin:0 0 0.5rem;color:var(--text-muted);">{a}</dd>
        </>
      ))}
    </dl>

    <h2>Contact</h2>
    <p>
      <a href="mailto:chaos.tc@gmail.com">chaos.tc@gmail.com</a>
    </p>
    <p style="color:var(--text-muted);font-size:0.875rem;">
      All opinions here are my own and do not represent my employer.
    </p>
  </div>
</Base>
