---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import { pulseSlug, sortedPulse } from "../../lib/posts";

export async function getStaticPaths() {
  const includeDrafts = !import.meta.env.PROD;
  const reports = sortedPulse(await getCollection("pulse"), includeDrafts);
  return reports.map(report => ({
    params: { slug: pulseSlug(report.id) },
    props: { report },
  }));
}

const { report } = Astro.props;
const { Content } = await render(report);

const dateStr = report.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});

const canonical = new URL(`/pulse/${pulseSlug(report.id)}/`, "https://tanchao.xyz").href;
const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: report.data.title,
  datePublished: report.data.date.toISOString(),
  dateModified: report.data.date.toISOString(),
  author: { "@type": "Person", "@id": "https://tanchao.xyz/#person", name: "Chao Tan" },
  url: canonical,
  isPartOf: { "@type": "WebSite", "@id": "https://tanchao.xyz/#website" },
  inLanguage: "en-US",
};
---

<Base
  title={report.data.title}
  description={report.data.description}
  type="article"
  publishedTime={report.data.date}
  canonicalUrl={canonical}
  noindex={report.data.draft}
  jsonLd={blogPostingSchema}
>
  <article>
    <header style="margin-bottom:2rem;">
      <h1>{report.data.title}</h1>
      <div style="font-family:var(--font-sans);font-size:0.875rem;color:var(--text-muted);display:flex;flex-wrap:wrap;gap:0.75rem;align-items:center;">
        <span>
          By <a href="/about/" rel="author" style="color:var(--text);text-decoration:none;border-bottom:1px dotted currentColor;">Chao Tan</a>
        </span>
        <span>· <time datetime={report.data.date.toISOString()}>{dateStr}</time></span>
        {report.data.week && <span>· {report.data.week}</span>}
      </div>
    </header>
    <div class="prose">
      <Content />
    </div>
    {report.data.sources && report.data.sources.length > 0 && (
      <section style="margin-top:2.5rem;border-top:1px solid var(--border);padding-top:1rem;">
        <h2 style="font-family:var(--font-sans);font-size:0.85rem;font-weight:600;color:var(--text-muted);letter-spacing:0.05em;text-transform:uppercase;">
          Sources
        </h2>
        <ul style="font-family:var(--font-sans);font-size:0.9rem;">
          {report.data.sources.map(s => (
            <li><a href={s.url} rel="noopener noreferrer">{s.title}</a></li>
          ))}
        </ul>
      </section>
    )}
  </article>
  <p style="margin-top:2rem;font-family:var(--font-sans);font-size:0.875rem;">
    <a href="/pulse/">← All AI Pulse reports</a>
  </p>
</Base>
