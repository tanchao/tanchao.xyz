---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
import { sortedPosts, allTags, postUrl } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = sortedPosts(await getCollection("posts"));
  const tags = allTags(posts);
  return tags.map(tag => ({
    params: { tag },
    props: { posts: posts.filter(p => p.data.tags.includes(tag)) },
  }));
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<Base title={`Tag: ${tag}`} description={`Posts tagged "${tag}" on tanchao's blog.`}>
  <h1>
    Tag: <span style="color:var(--link);">{tag}</span>
  </h1>
  <p style="font-family:var(--font-sans);font-size:0.9rem;color:var(--text-muted);margin-bottom:1.5rem;">
    {posts.length} post{posts.length !== 1 ? "s" : ""}
  </p>

  <ul style="list-style:none;padding:0;margin:0;">
    {posts.map(post => (
      <li style="display:flex;gap:1rem;align-items:baseline;padding:0.3rem 0;flex-wrap:wrap;">
        <time
          datetime={post.data.date.toISOString()}
          style="font-family:var(--font-sans);font-size:0.85rem;color:var(--text-muted);white-space:nowrap;min-width:6rem;"
        >
          {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
        </time>
        <a href={postUrl(post.id)}>{post.data.title}</a>
      </li>
    ))}
  </ul>

  <p style="margin-top:2rem;font-family:var(--font-sans);font-size:0.875rem;">
    <a href="/tags/">← All tags</a>
  </p>
</Base>
